<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vertx.worker.mvc.mapper.BookMapper">
    <!-- MyBatis read path; writes use Spring Data JPA in this sample. -->
    <select id="selectBookOne" parameterType="Long" resultType="com.vertx.worker.mvc.dto.Book" fetchSize="50">
        SELECT  ID     AS "id"
               ,NAME   AS  "name"
               ,AUTHOR AS "author"
               ,PAGES  AS "pages"
        FROM book
        WHERE ID = #{id}
    </select>

</mapper>
